# REQUIRED
DATABASE_URL=postgresql://user:password@localhost:5432/aiimage

# REQUIRED
REDIS_URL=redis://localhost:6379

# REQUIRED
JWT_SECRET=change-this-to-a-random-64-char-string-in-production

# OPTIONAL (default: 168)
JWT_EXPIRE_HOURS=168

# REQUIRED
OPENAI_API_KEY=sk-...

# REQUIRED
R2_ACCESS_KEY=...
# REQUIRED
R2_SECRET_KEY=...
# REQUIRED
R2_BUCKET=ai-image-prod
# REQUIRED
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# REQUIRED
R2_PUBLIC_URL=https://images.yourdomain.com

# REQUIRED
ALIYUN_SMS_KEY=...
# REQUIRED
ALIYUN_SMS_SECRET=...
# REQUIRED
ALIYUN_SMS_SIGN=你的签名
# REQUIRED
ALIYUN_SMS_TEMPLATE=SMS_xxxxx

# REQUIRED
HUPIJIAO_KEY=...
# REQUIRED
HUPIJIAO_SECRET=...

# OPTIONAL (default: 1)
MAX_DAILY_FREE_GENERATIONS=1
