# n8n 环境变量配置
# 复制此文件为 .env，然后修改下面的值
# 警告：.env 文件不得提交到 Git

# ── 登录认证 ──────────────────────────────
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# ── 服务器地址 ────────────────────────────
# 如果还没有域名，填写服务器公网 IP
N8N_HOST=8.218.40.11
N8N_PORT=5678
N8N_PROTOCOL=http

# 配置域名和 HTTPS 后改为：
# N8N_HOST=n8n.yourdomain.com
# N8N_PROTOCOL=https
# WEBHOOK_URL=https://n8n.yourdomain.com/

# 暂时用 IP 访问时：
WEBHOOK_URL=http://8.218.40.11:5678/

# ── 安全加密 ──────────────────────────────
# 用于加密存储的 Credentials，必须设置，不能修改
# 生成方法：openssl rand -hex 32
N8N_ENCRYPTION_KEY=CHANGE_THIS_RUN_openssl_rand_hex_32

# ── 时区 ──────────────────────────────────
GENERIC_TIMEZONE=Asia/Hong_Kong
