# LexiOcean AI Configuration
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# AI Provider selection
# Options: mock | openai | anthropic | gemini
# Default: mock (safe to use without any API keys)
AI_PROVIDER=mock

# API Keys — leave blank when using mock provider
# Do NOT hardcode these in any source file
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Model override (optional — each provider has a sensible default)
# OpenAI example:    gpt-4o-mini
# Anthropic example: claude-haiku-4-5-20251001
# Gemini example:    gemini-1.5-flash
AI_MODEL=

# Output token limit per request (default: 1024)
AI_MAX_OUTPUT_TOKENS=1024

# Enable in-memory response cache (default: true for mock, review for prod)
AI_ENABLE_CACHE=true

# Supabase Configuration (Phase 5B+)
# Create a project at https://supabase.com and copy these from:
# Project Settings → API
# Required for Auth and Cloud Sync features.
# Without these, auth is disabled but all other features work normally.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: used in /auth/logout redirect (defaults to http://localhost:3000)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Server-only secrets (NEVER prefix with NEXT_PUBLIC; never commit real values) ──
# Service role key — used by admin scripts + server-side signed-URL minting. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=

# R6 audio pipeline (Azure AI Speech Neural TTS, free tier F0 = 0.5M chars/month)
# Create a Speech resource in the Azure portal; copy key + region from Keys and Endpoint.
# Read ONLY by backend/scripts (generate/validate/review + session-builder signing). Never logged.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
# Private Supabase Storage bucket for synthesized audio (must be created as PRIVATE, not public).
SUPABASE_AUDIO_BUCKET=qbank-audio
