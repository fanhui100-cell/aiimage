  "items": [
    { "taskType": "synonym_choice", "examId": "toefl", "level": 6, "word": "gauge", "prompt": "gauge", "choices": ["measure", "ignore", "distort", "conceal"], "answer": "measure", "explainZh": "gauge≈measure 估量/测量；ignore 忽视、distort 扭曲、conceal 隐藏均非同义。" },
    { "taskType": "synonym_choice", "examId": "toefl", "level": 6, "word": "grim", "prompt": "grim", "choices": ["harsh", "cheerful", "gentle", "mild"], "answer": "harsh", "explainZh": "grim≈harsh 严峻冷酷；cheerful/gentle/mild 为愉快/温和，反义。" },
    { "taskType": "synonym_choice", "examId": "toefl", "level": 6, "word": "germinate", "prompt": "germinate", "choices": ["sprout", "wither", "decay", "harvest"], "answer": "sprout", "explainZh": "germinate≈sprout 发芽；wither 枯萎、decay 腐烂、harvest 收获均非同义。" },
    { "taskType": "synonym_choice", "examId": "toefl", "level": 6, "word": "hinder", "prompt": "hinder", "choices": ["impede", "assist", "facilitate", "promote"], "answer": "impede", "explainZh": "hinder≈impede 阻碍；assist/facilitate/promote 为帮助/促进，反义。" },
    { "taskType": "synonym_choice", "examId": "toefl", "level": 6, "word": "hoard", "prompt": "hoard", "choices": ["stockpile", "disperse", "squander", "distribute"], "answer": "stockpile", "explainZh": "hoard≈stockpile 囤积；disperse/squander/distribute 为散开/挥霍/分发，反义。" },
    { "taskType": "synonym_choice", "examId": "toefl", "level": 6, "word": "haphazard", "prompt": "haphazard", "choices": ["random", "orderly", "planned", "systematic"], "answer": "random", "explainZh": "haphazard≈random 杂乱随意；orderly/planned/systematic 为有序/计划，反义。" },
    { "taskType": "synonym_choice", "examId": "toefl", "level": 6, "word": "intricate", "prompt": "intricate", "choices": ["complex", "simple", "plain", "obvious"], "answer": "complex", "explainZh": "intricate≈complex 错综复杂；simple/plain/obvious 为简单/明了，反义。" },
    { "taskType": "synonym_choice", "examId": "toefl", "level": 6, "word": "imminent", "prompt": "imminent", "choices": ["impending", "remote", "distant", "delayed"], "answer": "impending", "explainZh": "imminent≈impending 即将来临；remote/distant/delayed 为遥远/推迟，反义。" },
    { "taskType": "synonym_choice", "examId": "toefl", "level": 6, "word": "inept", "prompt": "inept", "choices": ["incompetent", "skilled", "capable", "adept"], "answer": "incompetent", "explainZh": "inept≈incompetent 无能；skilled/capable/adept 为熟练/能干，反义。" },
    { "taskType": "synonym_choice", "examId": "toefl", "level": 6, "word": "jovial", "prompt": "jovial", "choices": ["cheerful", "gloomy", "sullen", "solemn"], "answer": "cheerful", "explainZh": "jovial≈cheerful 快活；gloomy/sullen/solemn 为阴郁/严肃，反义。" },
    { "taskType": "synonym_choice", "examId": "toefl", "level": 6, "word": "jolt", "prompt": "jolt", "choices": ["jar", "soothe", "calm", "steady"], "answer": "jar", "explainZh": "jolt≈jar 使震动/震惊；soothe/calm/steady 为抚慰/平稳，反义。" },
    { "taskType": "synonym_choice", "examId": "toefl", "level": 6, "word": "lucrative", "prompt": "lucrative", "choices": ["profitable", "costly", "worthless", "futile"], "answer": "profitable", "explainZh": "lucrative≈profitable 有利可图；costly 昂贵、worthless 无价值、futile 徒劳均非同义。" },
    { "taskType": "synonym_choice", "examId": "toefl", "level": 6, "word": "lavish", "prompt": "lavish", "choices": ["extravagant", "frugal", "modest", "sparse"], "answer": "extravagant", "explainZh": "lavish≈extravagant 奢华；frugal/modest/sparse 为节俭/朴素，反义。" },
    { "taskType": "synonym_choice", "examId": "toefl", "level": 6, "word": "linger", "prompt": "linger", "choices": ["remain", "depart", "vanish", "hasten"], "answer": "remain", "explainZh": "linger≈remain 停留；depart/vanish/hasten 为离开/消失/匆忙，反义。" },
    { "taskType": "synonym_choice", "examId": "toefl", "level": 6, "word": "meager", "prompt": "meager", "choices": ["scanty", "ample", "generous", "abundant"], "answer": "scanty", "explainZh": "meager≈scanty 贫乏；ample/generous/abundant 为充足/丰富，反义。" },
    { "taskType": "synonym_choice", "examId": "toefl", "level": 6, "word": "mitigate", "prompt": "mitigate", "choices": ["alleviate", "worsen", "aggravate", "intensify"], "answer": "alleviate", "explainZh": "mitigate≈alleviate 减轻；worsen/aggravate/intensify 为加剧，反义。" },
    { "taskType": "synonym_choice", "examId": "toefl", "level": 6, "word": "mundane", "prompt": "mundane", "choices": ["ordinary", "exotic", "remarkable", "novel"], "answer": "ordinary", "explainZh": "mundane≈ordinary 平凡；exotic/remarkable/novel 为奇特/非凡，反义。" },
    { "taskType": "synonym_choice", "examId": "toefl", "level": 6, "word": "notorious", "prompt": "notorious", "choices": ["infamous", "famous", "esteemed", "obscure"], "answer": "infamous", "explainZh": "notorious≈infamous 臭名昭著（贬义）；famous 著名（中性）、esteemed 受尊敬、obscure 无名，均不等同。" },
    { "taskType": "synonym_choice", "examId": "toefl", "level": 6, "word": "novice", "prompt": "novice", "choices": ["beginner", "expert", "veteran", "master"], "answer": "beginner", "explainZh": "novice≈beginner 新手；expert/veteran/master 为专家/老手，反义。" },
    { "taskType": "synonym_choice", "examId": "toefl", "level": 6, "word": "obscure", "prompt": "obscure", "choices": ["vague", "clear", "evident", "distinct"], "answer": "vague", "explainZh": "obscure≈vague 模糊；clear/evident/distinct 为清晰/明确，反义。" },
    { "taskType": "synonym_choice", "examId": "toefl", "level": 6, "word": "obstinate", "prompt": "obstinate", "choices": ["stubborn", "compliant", "flexible", "docile"], "answer": "stubborn", "explainZh": "obstinate≈stubborn 固执；compliant/flexible/docile 为顺从/灵活，反义。" },
    { "taskType": "synonym_choice", "examId": "toefl", "level": 6, "word": "plausible", "prompt": "plausible", "choices": ["credible", "absurd", "dubious", "implausible"], "answer": "credible", "explainZh": "plausible≈credible 可信；absurd/dubious/implausible 为荒谬/可疑/不可信，反义。" },
    { "taskType": "synonym_choice", "examId": "toefl", "level": 6, "word": "profound", "prompt": "profound", "choices": ["deep", "shallow", "trivial", "superficial"], "answer": "deep", "explainZh": "profound≈deep 深刻；shallow/trivial/superficial 为肤浅/琐碎，反义。" },
