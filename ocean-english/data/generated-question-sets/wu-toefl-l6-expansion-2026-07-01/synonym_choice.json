    { "taskType": "synonym_choice", "examId": "toefl", "level": 6, "word": "robust", "prompt": "robust", "choices": ["sturdy", "frail", "feeble", "fragile"], "answer": "sturdy", "explainZh": "robust≈sturdy 强健；frail/feeble/fragile 为虚弱/脆弱，反义。" },
    { "taskType": "synonym_choice", "examId": "toefl", "level": 6, "word": "scarce", "prompt": "scarce", "choices": ["rare", "abundant", "plentiful", "common"], "answer": "rare", "explainZh": "scarce≈rare 稀缺；abundant/plentiful/common 为丰富/常见，反义。" },
